import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt
from fft_module import compute_fft

st.title("Анализ временных рядов (FFT)")

uploaded_file = st.file_uploader("Загрузите CSV файл")

if uploaded_file:
    data = pd.read_csv(uploaded_file)
    signal = data.iloc[:, 0]

    st.write("Исходный сигнал")
    plt.plot(signal)
    st.pyplot(plt)

    if st.button("Выполнить FFT"):
        fft = compute_fft(signal)

        st.write("Спектр частот")
        plt.plot(fft)
        st.pyplot(plt)
